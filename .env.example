# Database Configuration (PostgreSQL g4public)
DB_HOST="localhost"            # Database host
DB_PORT=5432                   # Database port (PostgreSQL default)
DB_NAME="g4public"             # Database name
DB_USER="your_user_here"       # Database user (placeholder only — never commit real credentials)
DB_PASSWORD="your_password_here"  # Database password (placeholder only)

# Optional connection-pool tuning
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
